msgid "Cheating, plagiarism, or submitting false documents"
msgstr "Ko'chirish, plagiat yoki soxta hujjatlar topshirish"

msgid "Damage to university property or the environment"
msgstr "Universitet mulki yoki atrof-muhitga zarar yetkazish"

